{
    "useTabs": false,
    "tabWidth": 4,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5",
    "printWidth": 100,
    "arrowParens": "avoid",
    "overrides": [
        {
            "files": ["*.ts", "*.tsx", "*.js", "*.jsx", "*.vue"],
            "options": {
                "printWidth": 140
            }
        }
    ]
}
